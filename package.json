{
  "name": "github-actions",
  "version": "12.4.1",
  "description": "Common GitHub Actions used across my repositories.",
  "homepage": "https://github.com/AlexMan123456/github-actions#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexMan123456/github-actions.git"
  },
  "sideEffects": false,
  "license": "ISC",
  "author": "alextheman",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "exit 0",
    "create-release-note": "bash -c 'git pull origin main && alex-c-line template release-note create $@' --",
    "format": "pnpm run format-package-json && pnpm run format-prettier && pnpm run format-markdownlint",
    "format-markdownlint": "pnpm exec markdownlint-cli2 --fix \"**/*.md\" \"!{node_modules,dist}/**\" | grep -v \"^Finding:\"",
    "format-package-json": "eslint --fix --suppress-all package.json && rm -f eslint-suppressions.json",
    "format-prettier": "prettier --write \"./**/*.yml\"",
    "lint": "pnpm run lint-package-json && pnpm run lint-markdownlint && pnpm run lint-prettier",
    "lint-markdownlint": "bash -o pipefail -c 'pnpm exec markdownlint-cli2 \"**/*.md\" \"!{node_modules,dist}/**\"| grep -v \"^Finding:\"'",
    "lint-package-json": "eslint package.json",
    "lint-prettier": "prettier --check \"./**/*.yml\"",
    "pre-commit": "alex-c-line pre-commit",
    "prepare": "husky",
    "update-dependencies": "pnpm update --latest && pnpm update"
  },
  "devDependencies": {
    "@alextheman/eslint-plugin": "5.18.0",
    "@typescript-eslint/types": "8.63.0",
    "alex-c-line": "2.12.4",
    "eslint": "10.6.0",
    "husky": "9.1.7",
    "markdownlint-cli2": "0.23.0",
    "prettier": "3.9.5",
    "typescript-eslint": "8.63.0"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}
