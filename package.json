{
  "name": "github-actions",
  "version": "10.1.1",
  "description": "Common GitHub Actions used across my repositories.",
  "homepage": "https://github.com/AlexMan123456/github-actions#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexMan123456/github-actions.git"
  },
  "license": "ISC",
  "author": "alextheman",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "exit 0",
    "create-release-note": "bash -c 'git pull origin main && alex-c-line template release-note create $@' --",
    "format": "pnpm run format-package-json && pnpm run format-prettier && pnpm run format-zizmor",
    "format-package-json": "eslint --fix --suppress-all package.json && rm -f eslint-suppressions.json",
    "format-prettier": "prettier --write \"./**/*.yml\"",
    "format-zizmor": "zizmor --fix .",
    "lint": "pnpm run lint-package-json && pnpm run lint-zizmor && pnpm run lint-prettier",
    "lint-package-json": "eslint package.json",
    "lint-prettier": "prettier --check \"./**/*.yml\"",
    "lint-zizmor": "zizmor .",
    "pre-commit": "alex-c-line pre-commit",
    "prepare": "husky",
    "update-dependencies": "pnpm update --latest && pnpm update"
  },
  "devDependencies": {
    "@alextheman/eslint-plugin": "^5.10.2",
    "alex-c-line": "^2.2.5",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.1"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
