{
  "name": "github-actions",
  "version": "11.2.5",
  "description": "Common GitHub Actions used across my repositories.",
  "homepage": "https://github.com/AlexMan123456/github-actions#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexMan123456/github-actions.git"
  },
  "license": "ISC",
  "author": "alextheman",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "exit 0",
    "create-release-note": "bash -c 'git pull origin main && alex-c-line template release-note create $@' --",
    "format": "pnpm run format-package-json && pnpm run format-prettier",
    "format-package-json": "eslint --fix --suppress-all package.json && rm -f eslint-suppressions.json",
    "format-prettier": "prettier --write \"./**/*.yml\"",
    "lint": "pnpm run lint-package-json && pnpm run lint-prettier",
    "lint-package-json": "eslint package.json",
    "lint-prettier": "prettier --check \"./**/*.yml\"",
    "pre-commit": "alex-c-line pre-commit",
    "prepare": "husky",
    "update-dependencies": "pnpm update --latest && pnpm update"
  },
  "devDependencies": {
    "@alextheman/eslint-plugin": "5.15.0",
    "@typescript-eslint/types": "8.59.4",
    "alex-c-line": "2.7.2",
    "eslint": "10.4.0",
    "husky": "9.1.7",
    "prettier": "3.8.3",
    "typescript-eslint": "8.59.4"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
